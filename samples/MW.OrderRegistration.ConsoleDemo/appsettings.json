{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "MassTransit": "Information"
    }
  },
  "ConnectionStrings": {
    "DemoDb": "Host=localhost;Port=5432;Database=mw_order_demo;Username=postgres;Password=postgres"
  },
  "Messaging": {
    "ServiceName": "order-registration-demo",
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    },
    "Retry": {
      "RetryCount": 3,
      "RetryIntervalsInSeconds": [ 1, 2, 4 ]
    },
    "Redelivery": {
      "RedeliveryCount": 2,
      "RedeliveryIntervalsInSeconds": [ 5, 10 ]
    },
    "EnableHealthChecks": false
  },
  "SagaMassTransit": {
    "EndpointPrefix": "order-demo",
    "RetryCount": 3,
    "DefaultTimeoutInSeconds": 30,
    "UseScheduler": true
  },
  "Demo": {
    "Scenario": "success",
    "PaymentTimeoutSeconds": 30,
    "ResultQueryDelaySeconds": 10
  }
}
